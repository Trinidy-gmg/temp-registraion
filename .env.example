# Server-side only — set in Vercel/hosting env, never NEXT_PUBLIC_*
#
# RegistrationPage calls AdminSite for auth + mark-verified.
ADMINSITE_AUTH_BASE_URL=https://your-admin-site.example.com

# Optional: set to 1 on Vercel for extra [auth-backend] logs (host, status, JSON keys — no secrets).
# REGISTRATION_DEBUG_AUTH=1

# Debug only: return 200 without Set-Cookie (proves AdminSite/HAMS + JSON shape work). Remove after testing.
# REGISTRATION_SKIP_AUTH_COOKIES=1

# Optional: max combined bytes for both auth Set-Cookie headers (default 7500). Lower if proxy still 500s.
# REGISTRATION_MAX_SET_COOKIE_BYTES=7500

# Signed cookie for pending email verification (min 16 characters).
SIGNUP_VERIFY_SECRET=change-me-use-openssl-rand-base64-32

# Optional: code lifetime (default 15m). Milliseconds, between 60s and 24h.
# SIGNUP_VERIFY_CODE_TTL_MS=900000

# Same value as AdminSite REGISTRATION_VERIFY_SECRET (protects mark-email-verified).
REGISTRATION_VERIFY_SECRET=

# SendGrid — verification email (8-digit code)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Hollowed Oath
# Paste dynamic template ID after uploading templates/sendgrid/verification-code.html
SENDGRID_VERIFICATION_TEMPLATE_ID=
